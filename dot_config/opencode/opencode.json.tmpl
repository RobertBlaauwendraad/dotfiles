{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "jetbrains-1": {
      "type": "remote",
      "url": "http://127.0.0.1:64342/sse"
    },
    "jetbrains-2": {
      "type": "remote",
      "url": "http://127.0.0.1:64343/sse"
    },
    "gcp-observability": {
      "type": "local",
      "command": ["npx", "-y", "@google-cloud/observability-mcp"],
      "enabled": true
    },
    "cloud-sql-postgres": {
      "type": "local",
      "command": ["npx", "-y", "@toolbox-sdk/server", "--prebuilt", "cloud-sql-postgres", "--stdio"],
      "environment": {
        "CLOUD_SQL_POSTGRES_PROJECT": "{{ .work.gcpProject }}",
        "CLOUD_SQL_POSTGRES_REGION": "{{ .work.gcpRegion }}",
        "CLOUD_SQL_POSTGRES_INSTANCE": "{{ .work.gcpInstance }}",
        "CLOUD_SQL_POSTGRES_DATABASE": "{{ .work.gcpDatabase }}"
      },
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "drawio": {
      "type": "remote",
      "url": "https://mcp.draw.io/mcp",
      "enabled": false
    }
  }
}
