layout {
    tab name="claude" {
        pane split_direction="vertical" {
            // Agents: 2-3 sessions, launched here with `claude -w <name>`
            pane split_direction="horizontal" size="60%" {
                pane name="work-1" focus=true
                pane name="work-2"
                pane name="work-3"
            }
            // Control: your review + merge heartbeat
            pane name="control" size="40%"
        }
    }
}
