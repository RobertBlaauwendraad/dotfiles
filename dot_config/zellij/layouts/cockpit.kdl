// ~/.config/zellij/layouts/cockpit.kdl
// Tab layout summoned by the `cockpit` alias from inside the persistent "main"
// session: `zellij action new-tab --layout cockpit --cwd <repo>`.
//
// The full cockpit for working on a repo: nvim on the left (where reviewing
// happens too — `<leader>gv` opens diffview; `<leader>gw` picks a git worktree
// and reviews its changes right here, so you never leave this cockpit to look
// at an agent's worktree), lazygit on the right for staging, commits and
// history, and a spare shell below it (small but always visible).
// Fullscreen any pane with the zellij prefix then `f` (Ctrl+g, then f).
// Everything opens on the repo (--cwd).
//
// The 60/40 split is provisional: now that diff review lives in nvim (diffview)
// rather than in a lazygit<->nvim bounce, nvim may want more width and lazygit
// less. Tune once it's had some real use.
//
// A claude session runs in a floating pane that starts hidden
// (hide_floating_panes) — so normal cockpits just show nvim + lazygit. Reveal
// / hide it any time with the zellij prefix then `p` (Ctrl+g, then p —
// ToggleFloatingPanes); it's already running when you summon it.
//
// For isolated/parallel agent work in a git worktree, use `wt <path>` instead.
//
// Only tab-bar: the built-in status-bar just shows keybind hints, blank in our
// bindless Normal mode. Default layout drops it too, so tabs stay consistent.
layout hide_floating_panes=true {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane command="nvim" size="60%"
        pane split_direction="horizontal" size="40%" {
            pane command="lazygit" size="75%"
            pane size="25%"    // spare shell — always visible, doesn't hide lazygit
        }
    }
    floating_panes {
        pane command="claude" name="claude" {
            x "8%"
            y "6%"
            width "84%"
            height "82%"
        }
    }
}
