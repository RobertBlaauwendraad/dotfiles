" Search settings
set incsearch
set smartcase

" Turn on syntax highlighting
syntax on

" Show line numbers
set number

" Showfile stats
set ruler

" Use system clipboard
set clipboard=unnamed

" Hard mode
noremap <Up> <NOP>
noremap <Down> <NOP>
noremap <Left> <NOP>
noremap <Right> <NOP>
inoremap <Up> <NOP>
inoremap <Down> <NOP>
inoremap <Left> <NOP>
inoremap <Right> <NOP>
