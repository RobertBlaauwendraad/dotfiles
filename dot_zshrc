# uv (Python) — must be before instant prompt
[[ -f "$HOME/.local/bin/env" ]] && . "$HOME/.local/bin/env"

# Auto-start zellij — attach to one persistent session, create it if absent.
# Opens on a plain shell; run `cockpit` in a repo for the lazygit workspace.
if [[ -z "$ZELLIJ" && $TERM_PROGRAM == "ghostty" ]]; then
  exec zellij attach -c main
fi

# P10k instant prompt — must stay near top
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Zinit
source "${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git/zinit.zsh"

# P10k — synchronous so prompt appears immediately
zinit ice depth=1
zinit light romkatv/powerlevel10k

# Completion — regenerates dump once per day instead of every shell start
fpath=($HOME/.docker/completions $fpath)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# fzf-tab config — must be set before the plugin loads
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --icons $realpath'
zstyle ':fzf-tab:*' switch-group ',' '.'

# Plugins — async, order matters
zinit ice wait lucid
zinit snippet OMZP::git

# fzf-tab must load before widget-wrapping plugins (autosuggestions,
# syntax-highlighting) so they wrap its completion widget. Turbo-load
# autosuggestions in the same wait"0" bucket (loads after fzf-tab by source
# order); atload forces it to bind widgets on load, not at next precmd —
# without this the wrap loses a race and Tab leaves stale suggestions behind.
zinit ice wait lucid
zinit light Aloxaf/fzf-tab

zinit ice wait lucid atload'!_zsh_autosuggest_start'
zinit light zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit light MichaelAquilina/zsh-you-should-use

# Must be last
zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting

# History
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY

# Case insensitive completion
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Use emacs keymap — otherwise EDITOR=nvim makes zsh default to vi mode,
# where Esc enters command mode (prompt shows ❮) and letters run vi commands.
bindkey -e

# History search prefix matching
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# Autosuggestions — use history first, fall back to completion
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Environment
export EDITOR='nvim'
export HOMEBREW_NO_ENV_HINTS=true
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'

# PATH
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$HOME/Code/flutter/bin:$PATH"
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export PATH="$PATH:$HOME/.pub-cache/bin"
export PNPM_HOME="$HOME/Library/pnpm"
[[ ":$PATH:" != *":$PNPM_HOME:"* ]] && export PATH="$PNPM_HOME:$PATH"

# Tool init
eval "$(fzf --zsh)"
bindkey -r '^[c'  # drop fzf's Alt+c (cd) widget — fires on Esc c with caps→esc
if [[ -d "$HOME/.local/share/fnm" ]]; then
  eval "$(fnm env --use-on-cd --shell zsh --version-file-strategy=recursive --corepack-enabled --resolve-engines)"
  # Activate a version at init so `node` works even when no `cd` fires use-on-cd
  # (agents set cwd without a cd event). use-on-cd still switches per project.
  fnm use default >/dev/null 2>&1
fi

# Aliases
[[ -f ~/.config/zsh/aliases.zsh ]] && source ~/.config/zsh/aliases.zsh

# P10k config
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# zoxide — init LAST so its `cd` hook sits atop fnm's use-on-cd hook. Decide at
# CALL time (CLAUDECODE is set when cd runs, not when the harness sources this):
# humans get zoxide's frecency `cd`, agents get the real builtin so a wrong path
# errors instead of teleporting. `z`/`zi` still available for interactive jumps.
eval "$(zoxide init zsh)"
cd() { if [[ -n "$CLAUDECODE" ]]; then builtin cd "$@"; else z "$@"; fi }
