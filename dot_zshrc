# uv (Python) — must be before instant prompt
[[ -f "$HOME/.local/bin/env" ]] && . "$HOME/.local/bin/env"

export TERM=xterm-256color

# Auto-start zellij
if [[ -z "$ZELLIJ" && $TERM_PROGRAM == "ghostty" ]]; then
  exec zellij
fi

# P10k instant prompt — must stay near top
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Zinit
source "${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git/zinit.zsh"

# P10k — synchronous so prompt appears immediately
zinit ice depth=1
zinit light romkatv/powerlevel10k

# Completion — regenerates dump once per day instead of every shell start
fpath=($HOME/.docker/completions $fpath)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# fzf-tab config — must be set before the plugin loads
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --icons $realpath'
zstyle ':fzf-tab:*' switch-group ',' '.'

# Plugins — async, order matters
zinit ice wait lucid
zinit snippet OMZP::git

zinit ice wait lucid
zinit light Aloxaf/fzf-tab

zinit light zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit light MichaelAquilina/zsh-you-should-use

# Must be last
zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting

# History
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY

# Case insensitive completion
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# History search prefix matching
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# Autosuggestions — use history first, fall back to completion
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Modern CLI
eval "$(zoxide init zsh --cmd cd)"
eval "$(fzf --zsh)"

export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'

# fnm (Node)
if [[ -d "$HOME/.local/share/fnm" ]]; then
  eval "$(fnm env --use-on-cd --shell zsh --version-file-strategy=recursive --corepack-enabled --resolve-engines)"
fi

# Paths & tools
export PATH="$HOME/.jbang/bin:$HOME/.opencode/bin:$PATH"
export HOMEBREW_NO_ENV_HINTS=true
export EDITOR='nvim'

# Aliases
[[ -f ~/.config/zsh/aliases.zsh ]] && source ~/.config/zsh/aliases.zsh

# P10k config
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
